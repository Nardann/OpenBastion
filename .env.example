# PostgreSQL Configuration
POSTGRES_USER=bastion_user
POSTGRES_PASSWORD=bastion_password
POSTGRES_DB=bastion_db
POSTGRES_PORT=5432

# Database URL (constructed from PostgreSQL config above)
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# JWT & Vault Configuration
# Générer avec: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32"
VAULT_KEY="CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32"
VAULT_SALT="CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32"

# Server Configuration
FRONTEND_PORT=80
BACKEND_PORT=4000
NODE_ENV=production
CORS_ALLOWED_ORIGINS=https://localhost
RECORDINGS_PATH=/var/lib/bastion/recordings

# default admin credentials
ADMIN_EMAIL=admin@bastion.local
ADMIN_PASSWORD="CHANGE_ME_MIN_16_CHARS_WITH_COMPLEXITY"

# Rate Limiting Configuration
# Global: applies to all requests
THROTTLE_GLOBAL_TTL=1000
THROTTLE_GLOBAL_LIMIT=20

# Auth: specific limits for login, otp, and sudo
# TTL in milliseconds (e.g., 900000 = 15 minutes)
THROTTLE_AUTH_TTL=900000
THROTTLE_AUTH_LIMIT=20

